{
  "name": "kydra",
  "version": "2026.5.26b",
  "description": "Kydra Launcher",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --linux --win"
  },
  "keywords": [],
  "author": "K7 Sistemas",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.16.1",
    "cheerio": "^1.2.0",
    "express": "^5.2.1",
    "node-fetch": "^3.3.2",
    "openid": "^2.0.15"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.k7sistemas.kydra",
    "productName": "Kydra",
    "copyright": "Copyright © 2026 K7 Sistemas",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "art/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "art/icon.png",
      "category": "Game"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
